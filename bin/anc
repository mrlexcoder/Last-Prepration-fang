#!/bin/bash
set -e

PROJECT_ROOT="/opt/lampp/htdocs/myprepProjects/ANC_Official"
ANG_DIR="$PROJECT_ROOT/Searches/ANG_MVC"
VENV="$ANG_DIR/.venv"
BACKEND_PORT=8081
FRONTEND_PORT=5173

GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'; NC='\033[0m'

print_status() { echo -e "${GREEN}[ANC]${NC} $1"; }
print_error()  { echo -e "${RED}[ANC ERROR]${NC} $1"; }
print_warning(){ echo -e "${YELLOW}[ANC WARN]${NC} $1"; }

kill_on_port() {
    local port=$1
    if lsof -i :$port -sTCP:LISTEN -t >/dev/null 2>&1; then
        print_warning "Killing process on port $port"
        fuser -k ${port}/tcp 2>/dev/null || true
        sleep 1
    fi
}

ensure_core_deps() {
    cd "$ANG_DIR"
    source .venv/bin/activate

    CORE_PKGS="fastapi uvicorn[standard] jinja2 pydantic python-multipart httpx numpy"

    for pkg in $CORE_PKGS; do
        if ! python -c "import ${pkg%%[*]}" 2>/dev/null; then
            print_warning "Missing core package: $pkg — installing..."
            pip install "$pkg" --break-system-packages --quiet
        fi
    done
}

start_backend() {
    print_status "Starting Backend (FastAPI) on port $BACKEND_PORT..."
    cd "$ANG_DIR"

    if [ ! -d "$VENV" ]; then
        print_error "Venv not found. Run: python3 -m venv .venv && pip install -r requirements.txt --break-system-packages"
        exit 1
    fi

    ensure_core_deps

    PYTHON_BIN="$VENV/bin/python"
    kill_on_port $BACKEND_PORT

    nohup "$PYTHON_BIN" -m uvicorn app:app --host 0.0.0.0 --port $BACKEND_PORT --reload > /tmp/anc_backend.log 2>&1 &
    echo $! > /tmp/anc_backend.pid
    sleep 6

    if curl -s --max-time 4 http://localhost:$BACKEND_PORT/api/health >/dev/null 2>&1; then
        print_status "Backend started → http://localhost:$BACKEND_PORT"
    else
        print_error "Backend failed. Last 30 lines of log:"
        tail -30 /tmp/anc_backend.log
        exit 1
    fi
}

start_frontend() {
    print_status "Starting Frontend on port $FRONTEND_PORT..."
    cd "$ANG_DIR/anc_frontend"
    if [ ! -d node_modules ]; then npm install --silent 2>/dev/null || true; fi
    kill_on_port $FRONTEND_PORT
    nohup npm run dev -- --port $FRONTEND_PORT --host 0.0.0.0 > /tmp/anc_frontend.log 2>&1 &
    echo $! > /tmp/anc_frontend.pid
    sleep 5
    print_status "Frontend started → http://localhost:$FRONTEND_PORT"
}

start_full() {
    print_status "Starting full ANC system..."
    start_backend
    start_frontend
    echo ""
    print_status "System running!"
    echo "  Backend : http://localhost:8081"
    echo "  Frontend: http://localhost:5173"
}

stop_all() {
    print_status "Stopping..."
    [ -f /tmp/anc_backend.pid ] && kill $(cat /tmp/anc_backend.pid) 2>/dev/null || true
    [ -f /tmp/anc_frontend.pid ] && kill $(cat /tmp/anc_frontend.pid) 2>/dev/null || true
    kill_on_port $BACKEND_PORT
    kill_on_port $FRONTEND_PORT
    print_status "Stopped."
}

status() {
    echo "=== ANC Status ==="
    curl -s --max-time 2 http://localhost:$BACKEND_PORT/api/health >/dev/null && echo "Backend: RUNNING" || echo "Backend: STOPPED"
    curl -s --max-time 2 http://localhost:$FRONTEND_PORT >/dev/null && echo "Frontend: RUNNING" || echo "Frontend: STOPPED"
}

case "${1:-help}" in
    start)    start_full ;;
    backend)  start_backend ;;
    frontend) start_frontend ;;
    stop)     stop_all ;;
    status)   status ;;
    help)     echo "anc {start|backend|frontend|stop|status}";;
    *)        echo "Unknown. Use: anc help";;
esac
